# Brevo API Key for contact form emails
BREVO_API_KEY=

# Prise de rendez-vous (Google Calendar, OAuth refresh token)
# Obtenir le refresh token : node scripts/google-auth.mjs (instructions en tête du script).
# Sans ces variables, la section RDV affiche un message de repli vers l'assistant.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optionnel : agenda cible (defaut : primary)
GOOGLE_CALENDAR_ID=
